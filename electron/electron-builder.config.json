{
  "appId": "com.yourdoamnin.yourapp",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*",
    ".next/standalone/**/*",
    ".next/static/**/*"
  ],
  "publish": null,
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": "nsis",
    "icon": "assets/appIcon.ico"
  },
  "mac": {
    "category": "your.app.category.type",
    "target": "dmg",
    "hardenedRuntime": true,
    "entitlements": "entitlements.mac.plist",
    "entitlementsInherit": "entitlements.mac.plist",
    "extendInfo": {
      "NSCameraUsageDescription": "Aplikasi ini membutuhkan akses kamera untuk fitur Mirror.",
      "NSMicrophoneUsageDescription": "Aplikasi ini membutuhkan akses mikrofon untuk fitur Mirror."
    }
  }
}
